---
import { ClientRouter } from 'astro:transitions';
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import SEO from '../components/SEO.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CustomCursor from '../components/react/CustomCursor';
import DevModeToggle from '../components/react/DevModeToggle';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  class?: string;
}

const { title, description, image, noindex, class: className } = Astro.props;

const rawProjects = await getCollection('projects');
const projectsForDevMode = await Promise.all(
  rawProjects
    .sort((a, b) => a.data.order - b.data.order)
    .map(async (p) => ({
      slug: p.id,
      title: p.data.title,
      subtitle: p.data.subtitle,
      date: p.data.date.toISOString(),
      location: p.data.location ?? null,
      cover: (await getImage({ src: p.data.cover, width: 320 })).src,
    }))
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#C8E6FF" />
    <SEO title={title} description={description} image={image} noindex={noindex} />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <ClientRouter />
  </head>
  <body class="bg-background text-foreground antialiased">
    <!-- Skip to main content -->
    <a href="#main-content" class="skip-link">Skip to content</a>

    <!-- Noise overlay -->
    <div class="noise-overlay grain-animate" aria-hidden="true"></div>

    <!-- Custom cursor (desktop only) -->
    <CustomCursor client:load />

    <!-- Dev mode toggle — always visible, every page -->
    <DevModeToggle client:load projects={projectsForDevMode} />

    <Nav />

    <main id="main-content" class={className}>
      <slot />
    </main>

    <Footer />

    <!-- Mobile active-card observer (no-op on desktop) -->
    <script>
      import '../scripts/active-card-observer.ts'
    </script>
  </body>
</html>
